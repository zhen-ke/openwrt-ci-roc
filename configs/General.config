### 通用配置文件 ###

CONFIG_DEVEL=y
CONFIG_TARGET_OPTIONS=y
CONFIG_TARGET_OPTIMIZATION="-O3 -pipe -march=armv8-a+crypto+crc -mcpu=cortex-a53+crypto+crc -mtune=cortex-a53"

CONFIG_CCACHE=y
CONFIG_PACKAGE_default-settings=y
CONFIG_PACKAGE_default-settings-chn=y
CONFIG_TARGET_PER_DEVICE_ROOTFS=y
CONFIG_LUCI_LANG_zh_Hant=y

# CONFIG_FEED_nss_packages is not set
# CONFIG_FEED_sqm_scripts_nss is not set
# CONFIG_TARGET_ROOTFS_INITRAMFS is not set

CONFIG_PACKAGE_zram-swap=y
CONFIG_PACKAGE_kmod-lib-lz4=y
CONFIG_KERNEL_ZRAM_BACKEND_LZ4=y
CONFIG_KERNEL_ZRAM_BACKEND_LZO=y
CONFIG_KERNEL_ZRAM_DEF_COMP_LZ4=y

# 开启时固件默认集成所有的kmod内核模块
# CONFIG_ALL_KMODS is not set

CONFIG_PACKAGE_tmux=y
CONFIG_PACKAGE_dmesg=y
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_btop=n
CONFIG_PACKAGE_fdisk=y
CONFIG_PACKAGE_cfdisk=y
CONFIG_PACKAGE_sgdisk=y
CONFIG_PACKAGE_tune2fs=y
CONFIG_PACKAGE_ariang=y
CONFIG_PACKAGE_fstrim=y
CONFIG_PACKAGE_nano-full=y
CONFIG_PACKAGE_autocore=y
CONFIG_PACKAGE_coremark=y
CONFIG_PACKAGE_hdparm=y
CONFIG_PACKAGE_smartmontools-drivedb=y
CONFIG_PACKAGE_zoneinfo-asia=y
CONFIG_PACKAGE_acme-acmesh-dnsapi=y
CONFIG_PACKAGE_openssh-sftp-server=y
CONFIG_PACKAGE_ddns-scripts-cloudflare=y
CONFIG_PACKAGE_sqm-scripts-nss=y

CONFIG_PACKAGE_luci-theme-aurora=y
CONFIG_PACKAGE_luci-app-aurora-config=y
CONFIG_PACKAGE_luci-theme-argon=y
CONFIG_PACKAGE_luci-app-argon-config=y
CONFIG_PACKAGE_luci-app-cpufreq=y
CONFIG_PACKAGE_luci-app-ddns=y
CONFIG_PACKAGE_luci-app-ttyd=y
CONFIG_PACKAGE_luci-app-upnp=y
CONFIG_PACKAGE_luci-app-wol=y
CONFIG_PACKAGE_luci-app-samba4=y
CONFIG_PACKAGE_luci-app-vlmcsd=y
CONFIG_PACKAGE_luci-app-aria2=y
CONFIG_PACKAGE_luci-app-autoreboot=y
CONFIG_PACKAGE_luci-app-wifischedule=y
CONFIG_PACKAGE_luci-app-uhttpd=y
CONFIG_PACKAGE_luci-app-frps=n
CONFIG_PACKAGE_luci-app-frpc=n
CONFIG_PACKAGE_luci-app-diskman=y
CONFIG_PACKAGE_luci-app-hd-idle=y
CONFIG_PACKAGE_luci-app-banip=y
CONFIG_PACKAGE_luci-app-acme=y
CONFIG_PACKAGE_luci-app-arpbind=y
CONFIG_PACKAGE_luci-app-usb-printer=y
CONFIG_PACKAGE_luci-app-oaf=n
CONFIG_PACKAGE_luci-app-sqm=y
CONFIG_PACKAGE_luci-proto-wireguard=n
CONFIG_PACKAGE_luci-app-wechatpush=n
CONFIG_PACKAGE_luci-app-watchcat=n
CONFIG_PACKAGE_luci-app-3cat=n
CONFIG_PACKAGE_luci-app-smartdns=n
CONFIG_PACKAGE_luci-theme-bootstrap=y

# 网络相关

CONFIG_PACKAGE_ss=y
CONFIG_PACKAGE_kmod-tcp-bbr=y
CONFIG_DEFAULT_tcp_bbr=y
CONFIG_PACKAGE_tcpdump=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_tcping=y
CONFIG_PACKAGE_mtr=y
CONFIG_PACKAGE_iftop=y
CONFIG_PACKAGE_bind-dig=y
CONFIG_PACKAGE_iperf3=y

# ===== USB 相关 =====

# USB 基础工具
CONFIG_PACKAGE_usbutils=y           # lsusb 等 USB 设备查看工具
CONFIG_PACKAGE_automount=y          # USB 设备热插拔自动挂载
CONFIG_PACKAGE_lsblk=y              # 查看块设备树形结构
CONFIG_PACKAGE_blkid=y              # 识别磁盘分区 UUID 和文件系统类型
CONFIG_PACKAGE_mount-utils=y        # umount/findmnt 等挂载工具

# USB 存储驱动
CONFIG_PACKAGE_kmod-usb-storage=y       # USB 大容量存储基础驱动
CONFIG_PACKAGE_kmod-usb-storage-uas=y   # UAS 高速传输协议（USB 3.0 硬盘提速）
CONFIG_PACKAGE_kmod-usb-storage-extras=y # 额外 USB 存储兼容协议（quirks）
CONFIG_PACKAGE_kmod-usb3=y              # USB 3.0 xHCI 控制器驱动

# 文件系统内核模块
CONFIG_PACKAGE_kmod-fs-ext4=y       # EXT4，Linux 最常用文件系统
CONFIG_PACKAGE_kmod-fs-ntfs3=y      # NTFS3，内核原生驱动，性能优于 ntfs-3g
CONFIG_PACKAGE_kmod-fs-exfat=y      # exFAT，移动硬盘/U盘主流格式
CONFIG_PACKAGE_kmod-fs-vfat=y       # FAT32，兼容性最广
CONFIG_PACKAGE_kmod-fs-f2fs=y       # F2FS，闪存优化文件系统

# 字符集支持（FAT32/exFAT 中文文件名不乱码）
CONFIG_PACKAGE_kmod-nls-utf8=y      # UTF-8 编码（必须）
CONFIG_PACKAGE_kmod-nls-cp437=y     # FAT32 默认编码
CONFIG_PACKAGE_kmod-nls-iso8859-1=y # 西欧字符集兼容

# 磁盘格式化工具
CONFIG_PACKAGE_e2fsprogs=y          # mkfs.ext4 / fsck.ext4
CONFIG_PACKAGE_dosfstools=y         # mkfs.fat / mkfs.vfat（FAT32 格式化）


# ===== PassWall配置项 =====

# ===== nftables 内核模块 =====
CONFIG_PACKAGE_kmod-nft-core=y        # nftables 核心，其他模块的基础
CONFIG_PACKAGE_kmod-nft-nat=y         # NAT 转发（路由器基础功能）
CONFIG_PACKAGE_kmod-nft-tproxy=y      # 透明代理（PassWall nftables 模式必须）
CONFIG_PACKAGE_kmod-nft-socket=y      # socket 匹配（透明代理配套）
CONFIG_PACKAGE_kmod-nft-fib=y         # FIB 路由查找（分流/策略路由）
CONFIG_PACKAGE_kmod-nft-fullcone=y    # Full Cone NAT（改善游戏/P2P穿透）
CONFIG_PACKAGE_kmod-nft-offload=y     # 硬件/软件 offload 加速
CONFIG_PACKAGE_kmod-nft-dup-inet=y    # 数据包复制转发
CONFIG_PACKAGE_kmod-nft-connlimit=y   # 连接数限制
CONFIG_PACKAGE_kmod-nft-queue=y       # 数据包入队列（用户态处理）
CONFIG_PACKAGE_kmod-nft-arp=y         # ARP 包处理规则
CONFIG_PACKAGE_kmod-nft-bridge=y      # 桥接模式下的 nftables 规则
CONFIG_PACKAGE_kmod-nft-netdev=y      # netdev 钩子（ingress/egress 过滤）
CONFIG_PACKAGE_kmod-nft-xfrm=y        # IPsec/xfrm 策略匹配

CONFIG_PACKAGE_luci-app-passwall=y
# CONFIG_PACKAGE_luci-app-passwall_Iptables_Transparent_Proxy is not set
CONFIG_PACKAGE_luci-app-passwall_Nftables_Transparent_Proxy=y
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Geoview=y
# CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Haproxy is not set
# CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Hysteria is not set
# CONFIG_PACKAGE_luci-app-passwall_INCLUDE_NaiveProxy is not set
# CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Shadowsocks_Libev_Client is not set
# CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Shadowsocks_Libev_Server is not set
# CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Shadowsocks_Rust_Client is not set
# CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Shadowsocks_Rust_Server is not set
# CONFIG_PACKAGE_luci-app-passwall_INCLUDE_ShadowsocksR_Libev_Client is not set
# CONFIG_PACKAGE_luci-app-passwall_INCLUDE_ShadowsocksR_Libev_Server is not set
# CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Shadow_TLS is not set
# CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Simple_Obfs is not set
# CONFIG_PACKAGE_luci-app-passwall_INCLUDE_SingBox is not set
# CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Trojan_Plus is not set
# CONFIG_PACKAGE_luci-app-passwall_INCLUDE_tuic_client is not set
# CONFIG_PACKAGE_luci-app-passwall_INCLUDE_V2ray_Geodata is not set
# CONFIG_PACKAGE_luci-app-passwall_INCLUDE_V2ray_Plugin is not set
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Xray=y
# CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Xray_Plugin is not set
